# App
DEBUG=false

# Database (Neon PostgreSQL — pgvector is pre-installed on Neon)
# Get this from your Neon dashboard → Connection string → select asyncpg driver
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?ssl=require

# JWT
SECRET_KEY=your-super-secret-key-change-this
ACCESS_TOKEN_EXPIRE_DAYS=7

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_CHAT_DEPLOYMENT=gpt-4o-mini

# Instagram / Meta Developer App
# Requires: Instagram Business/Creator account + Meta Developer App
# Permissions needed: instagram_business_basic, instagram_business_manage_comments
INSTAGRAM_CLIENT_ID=your-meta-app-client-id
INSTAGRAM_CLIENT_SECRET=your-meta-app-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:8000/instagram/callback

# Google / YouTube OAuth
# Create a project at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: YouTube Data API v3
# OAuth consent screen scopes: https://www.googleapis.com/auth/youtube.readonly https://www.googleapis.com/auth/youtube.force-ssl
# Authorized redirect URI must match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/youtube/callback

# Frontend URL (for OAuth redirect after connecting)
FRONTEND_URL=http://localhost:3000

# Instagram scraper cookies — paste the full "cookie:" request header from DevTools
# (open Instagram in browser → F12 → Network → any instagram.com request → Request Headers → cookie:)
# This allows fetching comments from any public Instagram post without OAuth.
IG_COOKIES=
